<html> 
    <head> 
        <title>Catching error and error handling i JS</title>
    </head>
    <body> 
        <h2>JS error handlings</h2>
 <p>This is an example to demonstrate how to use <b>catch</b> to display an error</p>
        <p id="demo"></p>
        <script> 
           try{ 
            addalert("welcome to my website");
              }catch(err){
                document.getElementById("demo").innerHTML=err.message;
              }
        </script>
    </body>         
</html>
     